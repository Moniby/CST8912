<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || "Order Confirmed" %></title>
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
    <div class="container">
        <div class="confirmation-card">
            <h2>Thank you for your order!</h2>
            <p>Your order number is <strong>#<%= orderId || 'N/A' %></strong></p>
            <p>Payment status: <strong>PAID</strong></p>
            <a href="/products" class="primary-link">Continue Shopping</a>
        </div>
    </div>
</body>
</html>
