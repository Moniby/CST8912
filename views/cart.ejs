<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles/main.css" />
  </head>
  <body>
    <header class="hero">
      <div class="container">
        <nav class="top-nav centered-nav">
          <a href="/">Home</a>
          <a href="/about">About Us</a>
          <a href="/products">Products</a>
          <a href="/cart">Cart (<%= cartCount %>)</a>
        </nav>

        <div class="hero-top">
          <div>
            <h1>Your Cart</h1>
            <p>Review your items before proceeding to checkout.</p>
          </div>
          <a class="secondary-btn" href="/products">Continue Shopping</a>
        </div>
      </div>
    </header>

    <main class="container">
      <% if (cart.length === 0) { %>
      <div class="welcome-card" style="text-align: center;">
        <p>Your cart is empty. Add products from the store to get started.</p>
        <a class="primary-link" href="/products" style="display: inline-block; margin-top: 1rem;">Browse Products</a>
      </div>
      <% } else { %>
      <div class="table-wrap">
        <table class="cart-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Qty</th>
              <th>Subtotal</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% cart.forEach((item) => { %>
            <tr>
              <td><strong><%= item.product.Name %></strong></td>
              <td>$<%= Number(item.product.Price).toFixed(2) %></td>
              <td>
                <form action="/cart/update" method="post" class="inline-form" style="display: flex; gap: 5px;">
                  <input type="hidden" name="productId" value="<%= item.product.Id %>" />
                  <input type="number" name="quantity" min="1" value="<%= item.quantity %>" style="width: 60px;" />
                  <button type="submit" style="padding: 5px 10px; font-size: 0.8rem;">Update</button>
                </form>
              </td>
              <td>$<%= (Number(item.product.Price) * item.quantity).toFixed(2) %></td>
              <td>
                <form action="/cart/remove" method="post">
                  <input type="hidden" name="productId" value="<%= item.product.Id %>" />
                  <button class="danger-btn" type="submit" style="background-color: #dc3545;">Remove</button>
                </form>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <div style="margin-top: 2rem; text-align: right;">
        <h2 class="total-line">Total: $<%= total.toFixed(2) %></h2>
        <a class="primary-link" href="/checkout" style="font-size: 1.2rem; padding: 1rem 2rem;">Proceed to Checkout →</a>
      </div>
      <% } %>
    </main>
  </body>
</html>
