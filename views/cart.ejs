<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || "Your Cart" %></title>
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
    <header>
        <div class="container">
            <div class="hero">
                <div class="hero-top">
                    <h1>CST8912 Ecommerce Store Project</h1>
                    <a href="/cart" class="cart-link">Cart (<%= cartCount || 0 %>)</a>
                </div>
                <nav class="top-nav">
                    <a href="/">Home</a>
                    <a href="/products">Products</a>
                    <a href="/about">About</a>
                </nav>
            </div>
        </div>
    </header>

    <div class="container">
        <h2>Your Cart</h2>
        
        <% if ((cart || []).length === 0) { %>
            <p>Your cart is empty. <a href="/products">Browse products</a></p>
        <% } else { %>
            <table class="cart-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Qty</th>
                        <th>Subtotal</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% cart.forEach((item, index) => { %>
                    <tr>
                        <td><%= item.product.Name %></td>
                        <td>$<%= Number(item.product.Price).toFixed(2) %></td>
                        <td>
                            <form action="/cart/update" method="POST" class="inline-form">
                                <input type="hidden" name="index" value="<%= index %>">
                                <input type="number" name="quantity" value="<%= item.quantity %>" min="1" style="width:60px;">
                                <button type="submit">Update</button>
                            </form>
                        </td>
                        <td>$<%= (Number(item.product.Price) * item.quantity).toFixed(2) %></td>
                        <td>
                            <form action="/cart/remove" method="POST">
                                <input type="hidden" name="index" value="<%= index %>">
                                <button type="submit" class="danger-btn">Remove</button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            
            <p class="total-line">Total: $<%= total ? total.toFixed(2) : '0.00' %></p>
            <a href="/checkout" class="primary-link">Proceed to Checkout</a>
        <% } %>
    </div>
</body>
</html>
