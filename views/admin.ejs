<h2>Admin Dashboard</h2>

<h3>Add Product</h3>
<form method="POST" action="/admin/upload" enctype="multipart/form-data">
<input name="name">
<input name="price">
<input type="file" name="image">
<button>Add</button>
</form>

<h3>Products</h3>
<% products.forEach(p => { %>
<p><%= p.Name %></p>
<% }) %>

<h3>Orders</h3>
<% orders.forEach(o => { %>
<p>Order <%= o.Id %></p>
<% }) %>
