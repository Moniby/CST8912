<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles/main.css" />
  </head>
  <body>
    <header class="hero">
      <div class="container">
        <nav class="top-nav">
          <a href="/home">Home</a>
          <a href="/about">About Us</a>
          <a href="/products">Products</a>
          <a href="/cart">Cart (<%= cartCount %>)</a>
        </nav>
        <div class="hero-top">
          <div>
            <h1>CST8912 Ecommerce Store Project</h1>
            <p>The project is for CST 8912 - Cloud Solution Project Architecture, developed by Oluwatobi Monilari</p>
          </div>
          <a class="cart-link" href="/products">Shop Now</a>
        </div>
      </div>
    </header>

    <main class="container">
      <section class="confirmation-card">
        <h2>Welcome</h2>
        <p>
          Explore quality clothing and footwear for everyday style. Use the Products page
